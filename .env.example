# Application
APP_NAME=Dimora CRM
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://dimora:dimora_secret@localhost:5432/dimora_crm

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=dimora-files
S3_ENDPOINT_URL=http://localhost:9000

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token

# Facebook/Instagram Webhooks
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_VERIFY_TOKEN=your-facebook-verify-token

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# SMTP (Gmail: enable 2FA and create an App Password; paste without spaces)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Dimora CRM
# Send meeting/viewing reminders to the lead's email when Lead.email is set
EMAIL_NOTIFY_LEADS_ON_MEETING=false

# SMTP manual check (never commit real passwords or App Passwords to git):
# 1. Set SMTP_ENABLED=true and fill SMTP_USER, SMTP_PASSWORD (Gmail App Password, no spaces),
#    SMTP_FROM_EMAIL (often same as SMTP_USER), SMTP_FROM_NAME.
# 2. Run API + Celery worker with the same env (see docker-compose for api/celery-worker).
# 3. Trigger a manager task assignment (assignee with User.email) or wait for the 5-minute
#    activity reminder beat; confirm inbox. With EMAIL_NOTIFY_LEADS_ON_MEETING=true, MEETING
#    activities with Lead.email also email the lead.

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
